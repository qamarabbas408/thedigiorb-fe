{
  "info": {
    "name": "DigitalOrb API",
    "description": "API collection for DigitalOrb backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1"
    }
  ],
  "item": [
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Get All Contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["contacts"]
            },
            "description": "Get all contacts. Optional filter: ?status=new"
          }
        },
        {
          "name": "Create Contact",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["contacts"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"subject\": \"Inquiry\",\n    \"message\": \"Hello, I have a question...\",\n    \"phone\": \"+1234567890\"\n}"
            },
            "description": "Create a new contact"
          }
        },
        {
          "name": "Get Single Contact",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contacts/1",
              "host": ["{{baseUrl}}"],
              "path": ["contacts", "1"]
            },
            "description": "Get a single contact by ID"
          }
        },
        {
          "name": "Update Contact Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/contacts/1",
              "host": ["{{baseUrl}}"],
              "path": ["contacts", "1"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"read\"\n}"
            },
            "description": "Update contact status"
          }
        },
        {
          "name": "Delete Contact",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/contacts/1",
              "host": ["{{baseUrl}}"],
              "path": ["contacts", "1"]
            },
            "description": "Delete a contact"
          }
        }
      ]
    },
    {
      "name": "Portfolio Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/portfolio/categories",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "categories"]
            },
            "description": "Get all portfolio categories"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/portfolio/categories",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "categories"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Web Design\",\n    \"icon\": \"bi-globe\"\n}"
            },
            "description": "Create a new portfolio category"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/portfolio/categories",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "categories"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"id\": \"web-design\",\n    \"name\": \"Web Design Updated\",\n    \"icon\": \"bi-display\"\n}"
            },
            "description": "Update a portfolio category"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/portfolio/categories?id=web-design",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "categories"]
            },
            "description": "Delete a portfolio category by ID"
          }
        }
      ]
    },
    {
      "name": "Portfolio Projects",
      "item": [
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/portfolio/projects",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "projects"]
            },
            "description": "Get all projects. Filters: ?categoryId=web-design, ?status=published"
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/portfolio/projects",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "projects"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"New Project\",\n    \"subtitle\": \"Project Subtitle\",\n    \"categoryId\": \"web-design\",\n    \"year\": \"2024\",\n    \"technologies\": [\"Laravel\", \"React\"],\n    \"description\": \"Project description...\",\n    \"image\": \"/assets/img/portfolio/project.webp\",\n    \"gallery\": [\"/assets/img/gallery-1.webp\"],\n    \"featured\": true,\n    \"client\": \"Client Name\",\n    \"url\": \"https://example.com\",\n    \"status\": \"published\"\n}"
            },
            "description": "Create a new portfolio project"
          }
        },
        {
          "name": "Get Single Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/portfolio/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "projects", "1"]
            },
            "description": "Get a single project by ID"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/portfolio/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "projects", "1"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated Project\",\n    \"subtitle\": \"Updated Subtitle\",\n    \"categoryId\": \"web-design\",\n    \"year\": \"2024\",\n    \"technologies\": [\"Laravel\", \"React\", \"MySQL\"],\n    \"description\": \"Updated description...\",\n    \"featured\": false,\n    \"status\": \"draft\"\n}"
            },
            "description": "Update a portfolio project"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/portfolio/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "projects", "1"]
            },
            "description": "Delete a portfolio project"
          }
        }
      ]
    }
  ]
}
